<Window x:Class="GamingEqualizer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="400" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SETTINGS"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">

            <!-- Launch with Windows -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <CheckBox x:Name="LaunchWithWindowsCheck"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="LaunchWithWindows_Changed"
                          Unchecked="LaunchWithWindows_Changed"/>
                <TextBlock Text="Launch with Windows (starts minimized to tray)"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

            <!-- Default preset -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Default preset:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,12,0"/>
                <ComboBox x:Name="DefaultPresetCombo"
                          Width="160"
                          SelectionChanged="DefaultPresetCombo_SelectionChanged"/>
            </StackPanel>

            <!-- Re-run calibration -->
            <Button Content="♦ Re-run Hearing Calibration"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="RerunCalibration_Click"/>

            <!-- Sound Boost -->
            <TextBlock Text="SOUND BOOST"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <CheckBox x:Name="BoostEnabledCheck"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="Boost_Changed"
                          Unchecked="Boost_Changed"/>
                <TextBlock Text="Enable boost"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Slider x:Name="BoostSlider"
                        Minimum="0" Maximum="20" TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Width="220"
                        VerticalAlignment="Center"
                        ValueChanged="BoostSlider_ValueChanged"/>
                <TextBlock x:Name="BoostLabel"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{StaticResource TextBrush}"
                           Text="+0 dB"/>
            </StackPanel>

            <!-- Import / Export -->
            <TextBlock Text="PRESETS"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="⬆ Export Preset"
                        HorizontalAlignment="Left"
                        Margin="0,0,8,0"
                        Click="ExportPreset_Click"/>
                <Button Content="⬇ Import Preset"
                        HorizontalAlignment="Left"
                        Click="ImportPreset_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="⧉ Copy Share Code"
                        HorizontalAlignment="Left"
                        Margin="0,0,8,0"
                        Click="CopyShareCode_Click"/>
                <Button Content="⧉ Paste Share Code"
                        HorizontalAlignment="Left"
                        Click="PasteShareCode_Click"/>
            </StackPanel>

        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="2"
                Content="Close"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
