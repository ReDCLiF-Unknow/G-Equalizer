<Window x:Class="GamingEqualizer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="400" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SETTINGS"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">

            <!-- Launch with Windows -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <CheckBox x:Name="LaunchWithWindowsCheck"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="LaunchWithWindows_Changed"
                          Unchecked="LaunchWithWindows_Changed"/>
                <TextBlock Text="Launch with Windows (starts minimized to tray)"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

            <!-- Default preset -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Default preset:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,12,0"/>
                <ComboBox x:Name="DefaultPresetCombo"
                          Width="160"
                          SelectionChanged="DefaultPresetCombo_SelectionChanged"/>
            </StackPanel>

            <!-- Re-run calibration -->
            <Button Content="Re-run Hearing Calibration"
                    HorizontalAlignment="Left"
                    Click="RerunCalibration_Click"/>

        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="2"
                Content="Close"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
