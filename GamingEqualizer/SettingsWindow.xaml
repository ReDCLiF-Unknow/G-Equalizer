<Window x:Class="GamingEqualizer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="400" Height="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SETTINGS"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,12"
                      Padding="0,0,10,0">
        <StackPanel>

            <!-- Launch with Windows -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <CheckBox x:Name="LaunchWithWindowsCheck"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="LaunchWithWindows_Changed"
                          Unchecked="LaunchWithWindows_Changed"/>
                <TextBlock Text="Launch with Windows (starts minimized to tray)"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

            <!-- Default preset -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Default preset:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,12,0"/>
                <ComboBox x:Name="DefaultPresetCombo"
                          Width="160"
                          SelectionChanged="DefaultPresetCombo_SelectionChanged"/>
            </StackPanel>

            <!-- Re-run calibration -->
            <Button Content="♦ Re-run Hearing Calibration"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="RerunCalibration_Click"/>

            <!-- Sound Boost -->
            <TextBlock Text="SOUND BOOST"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <CheckBox x:Name="BoostEnabledCheck"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="Boost_Changed"
                          Unchecked="Boost_Changed"/>
                <TextBlock Text="Enable boost"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Slider x:Name="BoostSlider"
                        Minimum="0" Maximum="20" TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Width="220"
                        VerticalAlignment="Center"
                        ValueChanged="BoostSlider_ValueChanged"/>
                <TextBlock x:Name="BoostLabel"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{StaticResource TextBrush}"
                           Text="+0 dB"/>
            </StackPanel>

            <!-- Import / Export -->
            <TextBlock Text="PRESETS"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="⬆ Export Preset"
                        HorizontalAlignment="Left"
                        Margin="0,0,8,0"
                        Click="ExportPreset_Click"/>
                <Button Content="⬇ Import Preset"
                        HorizontalAlignment="Left"
                        Click="ImportPreset_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="⧉ Copy Share Code"
                        HorizontalAlignment="Left"
                        Margin="0,0,8,0"
                        Click="CopyShareCode_Click"/>
                <Button Content="⧉ Paste Share Code"
                        HorizontalAlignment="Left"
                        Click="PasteShareCode_Click"/>
            </StackPanel>

            <!-- AutoEQ import -->
            <TextBlock Text="HEADPHONE CORRECTION"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,12,0,10"/>
            <Button Content="⬇ Import AutoEQ (.txt)"
                    HorizontalAlignment="Left"
                    Click="ImportAutoEQ_Click"/>

            <!-- Auto-preset switching -->
            <TextBlock Text="AUTO-PRESET SWITCHING"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,20,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <CheckBox x:Name="AutoPresetCheck"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="AutoPreset_Changed"
                          Unchecked="AutoPreset_Changed"/>
                <TextBlock Text="Switch preset when foreground app changes"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

            <!-- Mapping list -->
            <Border BorderBrush="{StaticResource SectionBorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Process (.exe)" Grid.Column="0"
                                   FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="Preset" Grid.Column="1"
                                   FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                   Margin="8,0,0,0"/>
                    </Grid>
                    <ItemsControl x:Name="MappingList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Exe}" Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Preset}" Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource AccentTextBrush}"
                                               FontSize="11" Margin="8,0,0,0"/>
                                    <Button Content="✕" Grid.Column="2"
                                            Width="22" Height="22"
                                            FontSize="11"
                                            Style="{StaticResource IconButtonStyle}"
                                            Tag="{Binding Exe}"
                                            Click="RemoveMapping_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Add mapping row -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewExeBox"
                         Grid.Column="0"
                         Margin="0,0,6,0"
                         ToolTip="e.g. cs2.exe"
                         Text="process.exe"
                         Foreground="{StaticResource TextDimBrush}"
                         GotFocus="NewExeBox_GotFocus"
                         LostFocus="NewExeBox_LostFocus"/>
                <ComboBox x:Name="NewPresetCombo"
                          Grid.Column="1"
                          Margin="0,0,6,0"/>
                <Button Content="＋ Add"
                        Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddMapping_Click"/>
            </Grid>

        </StackPanel>
        </ScrollViewer>

        <!-- Close button -->
        <Button Grid.Row="2"
                Content="Close"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
