<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GamingEqualizer.OnboardingWizard"
        Title="Welcome to G-EQ"
        Width="500" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page host -->
        <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}">
            <Grid>
                <!-- Page 1: Welcome -->
                <StackPanel x:Name="Page1" IsVisible="True" VerticalAlignment="Center" Margin="48,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,14,0"
                                BoxShadow="0 0 18 0 #7c3aed99">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#7c3aed" Offset="0"/>
                                    <GradientStop Color="#db2777" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="G" Foreground="White" FontWeight="Black"
                                       FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" FontSize="26">
                            <Run Text="G"  Foreground="White"/>
                            <Run Text=" Equalizer" Foreground="#a78bfa"/>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="System-wide audio EQ for gamers"
                               FontSize="14" Foreground="{DynamicResource AccentTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,22"/>

                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource TextBrush}" TextAlignment="Center">
                        G-EQ adjusts your PC's audio in real time using EqualizerAPO.
                        Choose a gaming preset, fine-tune each frequency band, and calibrate
                        the EQ to your own hearing — all without touching audio drivers.
                    </TextBlock>
                </StackPanel>

                <!-- Page 2: Presets -->
                <StackPanel x:Name="Page2" IsVisible="False" VerticalAlignment="Center" Margin="48,0">
                    <TextBlock Text="🎮  GAMING PRESETS"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,18"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="FPS"       Foreground="#a78bfa" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Boosted highs for footsteps and gunshots"  Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RPG"       Foreground="#a78bfa" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Warm mids for voice and atmosphere"        Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cinematic" Foreground="#a78bfa" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Deep bass and rich soundstage for cutscenes" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Music"     Foreground="#a78bfa" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="V-curve: bass + treble lift for music"    Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Flat"      Foreground="#a78bfa" FontWeight="Bold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="No EQ applied — reference baseline"       Foreground="{DynamicResource TextBrush}"/>
                    </Grid>

                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                        You can also save your own custom presets by adjusting the sliders and clicking Save Preset.
                    </TextBlock>
                </StackPanel>

                <!-- Page 3: Hotkeys -->
                <StackPanel x:Name="Page3" IsVisible="False" VerticalAlignment="Center" Margin="48,0">
                    <TextBlock Text="⌨  GLOBAL HOTKEYS"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,18"/>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Background="#0d0d1a" BorderBrush="#252538"
                                BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,0,0,12">
                            <TextBlock Text="Ctrl + Alt + E" Foreground="#c4b5fd" FontFamily="Consolas" FontSize="13"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Toggle EQ on / off"
                                   Foreground="{DynamicResource TextBrush}" Margin="14,0,0,12" VerticalAlignment="Center"/>

                        <Border Grid.Row="1" Grid.Column="0" Background="#0d0d1a" BorderBrush="#252538"
                                BorderThickness="1" CornerRadius="4" Padding="10,6">
                            <TextBlock Text="Ctrl + Alt + P" Foreground="#c4b5fd" FontFamily="Consolas" FontSize="13"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Cycle to next preset"
                                   Foreground="{DynamicResource TextBrush}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                        Hotkeys work system-wide, even when G-EQ is minimized to the tray.
                        Use the tray icon to reopen the window or quit.
                    </TextBlock>
                </StackPanel>

                <!-- Page 4: Calibration -->
                <StackPanel x:Name="Page4" IsVisible="False" VerticalAlignment="Center" Margin="48,0">
                    <TextBlock Text="👂  HEARING CALIBRATION"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,18"/>

                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16">
                        Everyone hears differently. The calibration wizard plays a tone at each
                        frequency band and asks you to rate how clearly you hear it. G-EQ
                        uses your answers to build a personal EQ curve on top of any preset.
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20">
                        It takes about two minutes with headphones on and takes effect immediately.
                        You can re-run it any time from Settings.
                    </TextBlock>

                    <CheckBox x:Name="RunCalibrationCheck"
                              Content="Run the hearing calibration now"
                              IsChecked="True"
                              FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer: step dots + nav buttons -->
        <Border Grid.Row="1"
                Background="{DynamicResource TitlebarBrush}"
                BorderBrush="{DynamicResource SectionBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Step dots -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                    <Ellipse x:Name="Dot1" Width="7" Height="7" Margin="0,0,6,0" Fill="#7c3aed"/>
                    <Ellipse x:Name="Dot2" Width="7" Height="7" Margin="0,0,6,0" Fill="#252538"/>
                    <Ellipse x:Name="Dot3" Width="7" Height="7" Margin="0,0,6,0" Fill="#252538"/>
                    <Ellipse x:Name="Dot4" Width="7" Height="7"                   Fill="#252538"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BackBtn"
                            Content="Back"
                            Margin="0,0,8,0"
                            IsVisible="False"
                            Click="Back_Click"/>
                    <Button x:Name="NextBtn"
                            Content="Next"
                            Theme="{StaticResource PrimaryButtonTheme}"
                            Click="Next_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
