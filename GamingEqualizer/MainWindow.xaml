<Window x:Class="GamingEqualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="G Equalizer"
        Width="820" Height="610"
        MinWidth="740" MinHeight="560"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStyle="SingleBorderWindow"
        Closing="Window_Closing">

    <Border Background="{StaticResource AppSurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- Titlebar -->
                <RowDefinition Height="Auto"/> <!-- Error banner -->
                <RowDefinition Height="130"/>  <!-- Visualizer -->
                <RowDefinition Height="*"/>    <!-- EQ sliders -->
                <RowDefinition Height="54"/>   <!-- Preset chips -->
            </Grid.RowDefinitions>

            <!-- ── Titlebar ────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitlebarBrush}"
                    BorderBrush="{StaticResource SectionBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">
                        <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7c3aed" Offset="0"/>
                                    <GradientStop Color="#db2777" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7c3aed" BlurRadius="12"
                                                  ShadowDepth="0" Opacity="0.55"/>
                            </Border.Effect>
                            <TextBlock Text="G" Foreground="White" FontWeight="Black"
                                       FontSize="14" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" FontSize="16">
                            <Run Text="G"  Foreground="White"/>
                            <Run Text="EQ" Foreground="#a78bfa"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Status pill -->
                    <Border x:Name="StatusPill" Grid.Column="1"
                            BorderBrush="#7c3aed55" BorderThickness="1"
                            CornerRadius="12" Padding="10,4"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="6" Height="6"
                                     Fill="#7c3aed" Margin="0,0,7,0"/>
                            <TextBlock x:Name="StatusLabel" Text="EQ ACTIVE"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#a78bfa"/>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="⊞ Mini"
                                Margin="0,0,6,0"
                                Click="MiniModeButton_Click"/>
                        <Button x:Name="SettingsNavButton"
                                Content="⚙ Settings"
                                Margin="0,0,6,0"
                                Click="SettingsButton_Click"/>
                        <Button x:Name="BoostButton"
                                Content="⚡ BOOST"
                                Margin="0,0,6,0"
                                Width="90"
                                Click="BoostButton_Click"/>
                        <Button x:Name="ToggleButton"
                                Content="■ DISABLE"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="100"
                                Click="ToggleButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Error banner ────────────────────────────────────────── -->
            <Border x:Name="ErrorBanner"
                    Grid.Row="1"
                    Background="{StaticResource ErrorBrush}"
                    Padding="16,8"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontSize="12"/>
            </Border>

            <!-- ── Frequency visualizer ─────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource TitlebarBrush}"
                    BorderBrush="{StaticResource SectionBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="16,8,16,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="FREQUENCY RESPONSE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button x:Name="VizColorModeButton"
                                    Content="◈ GRADIENT"
                                    FontSize="10" Padding="7,2"
                                    Margin="0,0,6,0"
                                    Click="VizColorModeButton_Click"/>
                            <Button x:Name="LiveModeButton"
                                    Content="○ LIVE"
                                    FontSize="10" Padding="7,2"
                                    Click="LiveModeButton_Click"/>
                        </StackPanel>
                    </Grid>
                    <Canvas x:Name="VisualizerCanvas" Grid.Row="1"
                            SizeChanged="VisualizerCanvas_SizeChanged"/>
                </Grid>
            </Border>

            <!-- ── EQ sliders ──────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="{StaticResource SectionBgBrush}"
                    Padding="16,10,16,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="EQUALIZER"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"/>
                    <UniformGrid x:Name="SliderGrid"
                                 Grid.Row="1"
                                 Rows="1" Columns="10"
                                 HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- ── Preset chips ────────────────────────────────────────── -->
            <Border Grid.Row="4"
                    Background="{StaticResource TitlebarBrush}"
                    BorderBrush="{StaticResource SectionBorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="PRESET"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <StackPanel x:Name="ChipPanel" Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="SavePresetButton"
                                Content="＋ Save"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="26" Padding="10,0" FontSize="11"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                Click="SavePresetButton_Click"/>
                        <Button Content="♦ Calibrate"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="26" Padding="10,0" FontSize="11"
                                VerticalAlignment="Center"
                                Click="CalibrationButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Inline Settings Panel ──────────────────────────────── -->
            <Border x:Name="SettingsPanel"
                    Grid.Row="2" Grid.RowSpan="3"
                    Background="{StaticResource AppSurfaceBrush}"
                    Visibility="Collapsed">
                <Grid Margin="28,16,28,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SETTINGS"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,10,0">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">

                        <!-- Launch with Windows -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="LaunchWithWindowsCheck"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextBrush}"
                                      Checked="LaunchWithWindows_Changed"
                                      Unchecked="LaunchWithWindows_Changed"/>
                            <TextBlock Text="Launch with Windows (starts minimized to tray)"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>

                        <!-- Default preset -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="Default preset:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,12,0"/>
                            <ComboBox x:Name="DefaultPresetCombo"
                                      Width="160"
                                      SelectionChanged="DefaultPresetCombo_SelectionChanged"/>
                        </StackPanel>

                        <!-- Re-run calibration -->
                        <Button Content="♦ Re-run Hearing Calibration"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20"
                                Click="RerunCalibration_Click"/>

                        <!-- Sound Boost -->
                        <TextBlock Text="SOUND BOOST"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="BoostEnabledCheck"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextBrush}"
                                      Checked="Boost_Changed"
                                      Unchecked="Boost_Changed"/>
                            <TextBlock Text="Enable boost"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Slider x:Name="BoostSlider"
                                    Minimum="0" Maximum="20" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Width="220"
                                    VerticalAlignment="Center"
                                    ValueChanged="BoostSlider_ValueChanged"/>
                            <TextBlock x:Name="BoostLabel"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Foreground="{StaticResource TextBrush}"
                                       Text="+0 dB"/>
                        </StackPanel>

                        <!-- Presets import/export -->
                        <TextBlock Text="PRESETS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="⬆ Export Preset"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,8,0"
                                    Click="ExportPreset_Click"/>
                            <Button Content="⬇ Import Preset"
                                    HorizontalAlignment="Left"
                                    Click="ImportPreset_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="⧉ Copy Share Code"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,8,0"
                                    Click="CopyShareCode_Click"/>
                            <Button Content="⧉ Paste Share Code"
                                    HorizontalAlignment="Left"
                                    Click="PasteShareCode_Click"/>
                        </StackPanel>

                        <!-- AutoEQ import -->
                        <TextBlock Text="HEADPHONE CORRECTION"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,12,0,10"/>
                        <Button Content="⬇ Import AutoEQ (.txt)"
                                HorizontalAlignment="Left"
                                Click="ImportAutoEQ_Click"/>

                        <!-- Auto-preset switching -->
                        <TextBlock Text="AUTO-PRESET SWITCHING"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,20,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="AutoPresetCheck"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextBrush}"
                                      Checked="AutoPreset_Changed"
                                      Unchecked="AutoPreset_Changed"/>
                            <TextBlock Text="Switch preset when foreground app changes"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>

                        <!-- Mapping list -->
                        <Border BorderBrush="{StaticResource SectionBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Process (.exe)" Grid.Column="0"
                                               FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="Preset" Grid.Column="1"
                                               FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                               Margin="8,0,0,0"/>
                                </Grid>
                                <ItemsControl x:Name="MappingList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Exe}" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding Preset}" Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentTextBrush}"
                                                           FontSize="11" Margin="8,0,0,0"/>
                                                <Button Content="✕" Grid.Column="2"
                                                        Width="22" Height="22"
                                                        FontSize="11"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Tag="{Binding Exe}"
                                                        Click="RemoveMapping_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Add mapping row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewExeBox"
                                     Grid.Column="0"
                                     Margin="0,0,6,0"
                                     ToolTip="e.g. cs2.exe"
                                     Text="process.exe"
                                     Foreground="{StaticResource TextDimBrush}"
                                     GotFocus="NewExeBox_GotFocus"
                                     LostFocus="NewExeBox_LostFocus"/>
                            <ComboBox x:Name="NewPresetCombo"
                                      Grid.Column="1"
                                      Margin="0,0,6,0"/>
                            <Button Content="＋ Add"
                                    Grid.Column="2"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="AddMapping_Click"/>
                        </Grid>

                    </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
