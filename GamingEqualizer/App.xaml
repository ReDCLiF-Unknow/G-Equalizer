<Application x:Class="GamingEqualizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ── Palette ─────────────────────────────────────────────── -->
            <SolidColorBrush x:Key="BackgroundBrush"    Color="#06060e"/>
            <SolidColorBrush x:Key="AppSurfaceBrush"    Color="#0b0b16"/>
            <SolidColorBrush x:Key="TitlebarBrush"      Color="#07070f"/>
            <SolidColorBrush x:Key="SectionBgBrush"     Color="#08080f"/>
            <SolidColorBrush x:Key="SurfaceBrush"       Color="#0d0d1a"/>
            <SolidColorBrush x:Key="SectionBorderBrush" Color="#181828"/>
            <SolidColorBrush x:Key="AccentBrush"        Color="#7c3aed"/>
            <SolidColorBrush x:Key="AccentPinkBrush"    Color="#f472b6"/>
            <SolidColorBrush x:Key="AccentTextBrush"    Color="#a78bfa"/>
            <SolidColorBrush x:Key="TextBrush"          Color="#c4c4d0"/>
            <SolidColorBrush x:Key="TextDimBrush"       Color="#44445a"/>
            <SolidColorBrush x:Key="MutedTextBrush"     Color="#2a2a44"/>
            <SolidColorBrush x:Key="ErrorBrush"         Color="#db2777"/>

            <!-- ── Transparent slider (interaction-only, visuals are in Canvas overlay) -->
            <Style x:Key="TransparentSliderStyle" TargetType="Slider">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Track x:Name="PART_Track" Orientation="Vertical"
                                   Height="{TemplateBinding Height}"
                                   Width="{TemplateBinding Width}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="22" Height="22" IsTabStop="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Rectangle Fill="Transparent" Width="22" Height="22"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ScrollBar ──────────────────────────────────────────── -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width"      Value="6"/>
                <Setter Property="MinWidth"   Value="6"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid x:Name="Root" Width="6">
                                <Border Background="#0d0d1a" CornerRadius="3"/>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                                      Opacity="0"
                                                      Focusable="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="Bd"
                                                            Background="#7c3aed"
                                                            CornerRadius="3"
                                                            Margin="0,2"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#a78bfa"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#f472b6"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                                      Opacity="0"
                                                      Focusable="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Button base ────────────────────────────────────────── -->
            <Style TargetType="Button">
                <Setter Property="Background"       Value="#0d0d1a"/>
                <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush"      Value="#252538"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="Padding"          Value="12,6"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FontSize"         Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#44447a"/>
                                    <Setter TargetName="Bd" Property="Background"  Value="#12122a"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1a1a35"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary button (deep violet) -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="#5b21b6"/>
                <Setter Property="BorderBrush"     Value="#7c3aed"/>
                <Setter Property="Foreground"      Value="#ede9fe"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="12,6"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"  Value="#6d28d9"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#a78bfa"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#4c1d95"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Danger button (pink tint) -->
            <Style x:Key="DangerButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background"  Value="#db277710"/>
                <Setter Property="BorderBrush" Value="#db277766"/>
                <Setter Property="Foreground"  Value="#f472b6"/>
            </Style>

            <!-- Icon/remove button (borderless, small) -->
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{StaticResource TextDimBrush}"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#f472b6"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="#db2777"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Preset chip (ToggleButton) ─────────────────────────── -->
            <Style x:Key="ChipStyle" TargetType="ToggleButton">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource TextDimBrush}"/>
                <Setter Property="BorderBrush"     Value="#1e1e34"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14,5"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Margin"          Value="4,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7c3aed55"/>
                                    <Setter Property="Foreground" Value="#8877cc"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7c3aed99"/>
                                    <Setter TargetName="Bd" Property="Background"  Value="#7c3aed1a"/>
                                    <Setter Property="Foreground" Value="#c4b5fd"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── CheckBox ───────────────────────────────────────────── -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <BulletDecorator>
                                <BulletDecorator.Bullet>
                                    <Border x:Name="Box" Width="16" Height="16" CornerRadius="3"
                                            Background="#0d0d1a" BorderBrush="#252538" BorderThickness="1">
                                        <TextBlock x:Name="Check" Text="✓" FontSize="11" FontWeight="Bold"
                                                   Foreground="#7c3aed" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                                    </Border>
                                </BulletDecorator.Bullet>
                                <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                            </BulletDecorator>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Box"   Property="BorderBrush" Value="#7c3aed"/>
                                    <Setter TargetName="Box"   Property="Background"  Value="#7c3aed1a"/>
                                    <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush" Value="#7c3aed55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── TextBox ────────────────────────────────────────────── -->
            <Style TargetType="TextBox">
                <Setter Property="Background"   Value="#0d0d1a"/>
                <Setter Property="Foreground"   Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush"  Value="#252538"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"      Value="8,6"/>
                <Setter Property="CaretBrush"   Value="{StaticResource AccentTextBrush}"/>
                <Setter Property="SelectionBrush" Value="#7c3aed55"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Padding="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7c3aed99"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7c3aed55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ComboBox ───────────────────────────────────────────── -->
            <Style TargetType="ComboBox">
                <Setter Property="Background"      Value="#0d0d1a"/>
                <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush"     Value="#252538"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                              Focusable="False" ClickMode="Press" Cursor="Hand">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd"
                                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                BorderThickness="1" CornerRadius="4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition/>
                                                                    <ColumnDefinition Width="24"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="1" Text="▾"
                                                                           Foreground="#44445a"
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="10"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7c3aed55"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7c3aed99"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="8,5,28,5"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom" AllowsTransparency="True"
                                       Focusable="False"
                                       Width="{TemplateBinding ActualWidth}">
                                    <Border Background="#0d0d1a" BorderBrush="#252538"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="0,2,0,0">
                                        <ScrollViewer MaxHeight="200"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Padding"    Value="8,6"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#7c3aed1a"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#7c3aed2a"/>
                                    <Setter Property="Foreground" Value="#c4b5fd"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
